# --- Core ---
ENABLED_PLUGINS=site24x7,securityhub,aws_billing,drata,gmail,github,weather,news,stocks,trump,osint
LOG_LEVEL=INFO
RUN_WINDOW_HOURS=24
JARVIS_DRY_RUN=false
JARVIS_OUTPUT_DIR=/app/output    # bind-mounted to ./output on the host (see compose.yml)
# JARVIS_OUTPUT_FILE=            # override the full output path (takes precedence over JARVIS_OUTPUT_DIR)

# --- Groq ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REQUESTS_PER_MINUTE=30
GROQ_TOKENS_PER_MINUTE=60000
GROQ_WORKER_CONCURRENCY=2
GROQ_MAX_RETRIES=4

# --- Slack ---
# Omit SLACK_BOT_TOKEN (or leave blank) to write the digest to a markdown file instead.
# JARVIS_OUTPUT_FILE overrides the default filename (jarvis-brief-YYYY-MM-DD.md).
SLACK_BOT_TOKEN=xoxb-...
SLACK_TARGET_TYPE=user
SLACK_TARGET_ID=D0XXXXXXXXX
SLACK_USERNAME=Jarvis
SLACK_ICON_EMOJI=:robot_face:
# JARVIS_OUTPUT_FILE=./brief.md

# --- Site24x7 ---
SITE24X7_ZOHO_REFRESH_TOKEN=...
SITE24X7_CLIENT_ID=...
SITE24X7_CLIENT_SECRET=...
SITE24X7_DATACENTER=us

# --- AWS SecurityHub ---
SECURITYHUB_AWS_REGION=us-east-1
SECURITYHUB_AWS_ACCESS_KEY_ID=...
SECURITYHUB_AWS_SECRET_ACCESS_KEY=...
SECURITYHUB_MAX_FINDINGS=200

# --- AWS Billing ---
BILLING_AWS_REGION=us-east-1
BILLING_AWS_ACCESS_KEY_ID=...
BILLING_AWS_SECRET_ACCESS_KEY=...
BILLING_CURRENCY=USD
BILLING_GROUP_BY=SERVICE

# --- Drata ---
DRATA_API_KEY=...
DRATA_BASE_URL=https://public-api.drata.com


# --- Gmail ---
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...
GMAIL_USER=...
GMAIL_QUERY=in:inbox newer_than:1d

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_USER=...
GITHUB_ORGS=...
GITHUB_REPOS=
GITHUB_STALE_PR_DAYS=14

# --- Weather ---
WEATHER_ZIP_CODE=43017
WEATHER_COUNTRY_CODE=US
WEATHER_UNITS=imperial

# --- News ---
# Note: apnews.com/index.rss now returns 401 — replaced with Reuters via Yahoo News RSS
NEWS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,http://rss.cnn.com/rss/cnn_topstories.rss,https://moxie.foxnews.com/google-publisher/us.xml,https://feeds.npr.org/1001/rss.xml,https://www.theguardian.com/international/rss,https://news.yahoo.com/rss/
NEWS_ITEMS_PER_FEED=10
NEWS_DEDUPE=true

# --- Stocks ---
STOCKS_TICKERS=AAPL,MSFT,NVDA,GOOGL
STOCKS_INCLUDE_INDICES=true
STOCKS_NEWS_PER_TICKER=3
STOCKS_PROVIDER=yfinance
ALPHA_VANTAGE_API_KEY=

# --- OSINT / Threat Intel ---
# Sources to enable (comma-separated). All six are on by default.
# Remove a source name to skip it entirely.
# urlhaus, threatfox, and otx require their respective API keys below to activate.
OSINT_SOURCES=cisa_kev,nvd,urlhaus,threatfox,feodo,otx
# NVD API key (optional, free — nvd.nist.gov/developers/request-an-api-key — raises rate limit from 5 to 50 req/30s)
OSINT_NVD_API_KEY=
# URLhaus API key (free — urlhaus.abuse.ch, sign in and copy key from your profile)
OSINT_URLHAUS_API_KEY=
# ThreatFox API key (free — threatfox.abuse.ch, sign in and copy key from your profile)
OSINT_THREATFOX_API_KEY=
# AlienVault OTX API key (free — otx.alienvault.com, copy key from profile settings)
OSINT_OTX_API_KEY=
# Tuning (all optional — defaults shown)
# OSINT_NVD_MIN_CVSS=7.0        # minimum CVSS score to include
# OSINT_NVD_MAX_CVES=40         # cap on CVEs sent to Groq
# OSINT_URLHAUS_LIMIT=100       # entries to request from URLhaus API
# OSINT_URLHAUS_MAX_ITEMS=50    # cap on URLhaus items sent to Groq
# OSINT_THREATFOX_MAX_ITEMS=50  # cap on ThreatFox IoCs sent to Groq

# --- Trump ---
TRUMP_FEED_URL=https://www.trumpstruth.org/feed
TRUMP_MAX_POSTS=50
