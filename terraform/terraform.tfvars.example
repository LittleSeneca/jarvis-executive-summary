# Copy this file to terraform.tfvars and set values for your environment.
# terraform.tfvars is gitignored — never commit it.

# AWS credentials
aws_region  = "us-east-1"
aws_profile = ""          # blank = default credential chain

# Networking
# vpc_id: use "default" for the account default VPC, or a specific VPC ID.
# subnet_ids: explicit private subnet IDs (overrides VPC lookup). Leave empty
#   to auto-discover all subnets in the VPC.
# assign_public_ip: false for private subnets with NAT gateway (recommended);
#   true only if using public subnets without a NAT gateway.
vpc_id      = "default"
subnet_ids  = []   # e.g. ["subnet-aaa", "subnet-bbb", "subnet-ccc"]
assign_public_ip = false

# Schedule — EventBridge cron + IANA timezone
# cron(Minutes Hours Day-of-month Month Day-of-week Year)
# Below: 8:00 AM every day, Eastern Time
schedule_cron     = "cron(0 8 * * ? *)"
schedule_timezone = "America/New_York"

# ECS Fargate sizing (512 CPU / 1024 MB is plenty for the workload)
task_cpu    = 512
task_memory = 1024

# Image tag — "latest" always runs the most recently merged build
image_tag = "latest"

# CloudWatch log retention
log_retention_days = 30
